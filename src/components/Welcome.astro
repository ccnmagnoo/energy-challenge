---
import ecMotion from '../assets/ec-loop.svg'
import { ctx } from '../models/ChallengeContext'
import Planner from './Planner.astro'
import SponsorSection from './SponsorsSection.astro'
import Steps from './steps/Steps.astro'
import Subscribe from './SubscribeButton.astro'
import Subtitle from './Subtitle.astro'
---

<main>
	<section id="hero">
		<!-- <a href="http://tinyurl.com/ec-inscripcion"> -->
		<a href="#">
			<img id="hero-logo" src={ecMotion.src} alt="EnergyChallenge" />
		</a>
		<h1 id="year">
			{ctx.year}
		</h1>
		<Subscribe />
		<Subtitle />
		<SponsorSection />
		<Planner />
	</section>
	<section id="steps">
		<Steps/>

	</section>
</main>

<style>
	main {
		/* border: 1px solid red; */
		position: relative;
		margin: 2rem;
		min-width: min(800px, 100%);
		z-index: 1;
	}
	#hero {
		font-family: Roboto, Arial, sans-serif;
		display: flex;
		flex-direction: column;
		align-items: center;
		margin-top: 20%;
		justify-content: flex-start;
		z-index: 0;
		/* border: 1px red solid; */
		/* margin-top: 1vh; */
	}
	#hero-logo{
		animation: fadeIn 1s ease-in-out;
		opacity: 1;
		min-width: min(700px, 80dvw);
		z-index: 2;
	}
	@keyframes fadeIn {
		from{
			opacity: 0;
			transform: translateY(20px);
			transform: scale(1.2);
		}
		to{
			opacity: 1;
			transform: translateY(0);
			transform: scale(1);
		}
	}

	#year {
		position: absolute;
		font-size: 18rem;
		color: #fffdfd;
		margin: 0;
		padding: 0;
		z-index: -1;
		text-shadow: 0px 0px 10px #fff;
		/* filter: opacity(0.5); */
		opacity: 0.6;
		animation: flickering 1s ease-in-out;
		backdrop-filter: blur(5px);

	}
	@keyframes flickering {
		from{
			opacity: 0;
			transform: scale(.8);
		}
		to{
			opacity: 0.6;
			transform: scale(1);		
		}
	}

	@media screen and (max-width: 600px) {
		#hero {
			#year {
				font-size: 7rem;
			}
		}
	}
</style>
