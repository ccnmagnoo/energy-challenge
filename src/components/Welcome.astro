---
import ecMotion from '../assets/ec-loop.svg'
import { ctx } from '../models/ChallengeContext'
import Planner from './Planner.astro'
import SponsorSection from './SponsorsSection.astro'
import Subscribe from './SubscribeButton.astro'
import Subtitle from './Subtitle.astro'
---

<main>
	<section id="hero">
		<!-- <a href="http://tinyurl.com/ec-inscripcion"> -->
		<a href="#">
			<img class="heroLogo" src={ecMotion.src} alt="EnergyChallenge" />
		</a>
		<h1 id="year">
			{ctx.year}
		</h1>
		<Subscribe />
		<Subtitle />
		<SponsorSection />
		<Planner />
	</section>
</main>

<style>
	main {
		/* border: 1px solid red; */
		position: relative;
		margin: 2rem;
		min-width: min(800px, 100%);
		z-index: 1;
	}
	#hero {
		font-family: Roboto, Arial, sans-serif;
		display: flex;
		flex-direction: column;
		align-items: center;
		margin-top: 20%;
		justify-content: flex-start;
		z-index: 0;
		/* border: 1px red solid; */
		/* margin-top: 1vh; */

		#year {
			position: absolute;
			font-size: 18rem;
			color: #fffdfd;
			margin: 0;
			padding: 0;
			z-index: -1;
			text-shadow: 0px 0px 10px #fff;
			filter: opacity(0.5);
			animation: flickering-year 6s ease-in-out infinite alternate-reverse;

		}
		@keyframes flickering-year {
			from{
				filter:opacity(0.1);
			}
			to{
				filter:opacity(0.8);
			}
		}

		img.heroLogo {
			min-width: min(700px, 80dvw);
			z-index: 2;
		}
	}
	@media screen and (max-width: 600px) {
		#hero {
			#year {
				font-size: 7rem;
			}
		}
	}
</style>
