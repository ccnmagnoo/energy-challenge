---
import { ctx } from '../models/ChallengeContext'
import SponsorCard from './SponsorCard.astro'

const sponsors = ctx.sponsors
---
<article class="sponsors">
	<p>con el gentil auspicio de</p>
	<div class="container">
		{sponsors.map((it) => <SponsorCard name={it.name} url={it.url} logo={it.logo} />)}
	</div>
</article>
<style>
	.sponsors {
		display: block;
		margin-top: 2rem;
		/* background: rgb(0, 0, 0,0.5); */
		border-radius: 8px;

		/* border: 1px red solid; */
		p {
			margin: 8px;
			font-size: 0.8rem;
			color: #999;
		}
		.container {
			display: flex;
			gap: 10px;
			flex-wrap: wrap;
			justify-content: center;
			align-items: center;
		}
	}
	@media screen and (max-width:600px) {
		.sponsors{
			display: flex;
			flex-direction: column;
		}
		
	}
</style>
