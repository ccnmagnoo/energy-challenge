---
import Layout from '../layouts/Layout.astro';
import HeroLogo from './HeroLogo.astro';
const {hasPlayer} = Astro.props
---
<Layout hasPlayer={hasPlayer}>
    <HeroLogo/>
    <section class="rules">
        <slot/>
    </section>
</Layout>
<style>
    .rules {
        --primary:#9f2dfc;
        --secondary:#05d1ec;
        --accent:#e958ff;
        font-family: Roboto, Arial, sans-serif;
        z-index: 2;
        max-width: 680px;
        background-color: rgba(0, 0, 0, 0.678);
        padding:2rem;
        border-radius: 1rem;
        line-height: 1.6;
        font-size: 1.1rem;
        color:white;
        
        .rules-article{
            position:relative;
            display: flex;
            flex-direction: column;
        }
        p{
            margin:0;
        }
        img{
            width: 320px;
            height: 220px;
            object-fit:cover;
            border-radius: 2em;
            align-self: center;
        }

        h2, h3, h4{
            color:var(--primary);
            margin-top:2rem;
            margin-bottom:.5rem;
        }

        bold{
            color: var(--secondary);
            font-weight: 600;
        }
        a.innerlink{
            color:#afafaf;
            text-decoration: none;
            &::after{
                content: '🔗';
                font-size: .7rem;
            }
        }

      
        a.button{
            color:white;
            background-color: var(--primary);
            text-decoration: none;
            padding:1rem 1.4rem;
            margin:2rem auto;
            font-weight: 600;
            transition: all .1s ease-in-out;
            align-self: center;

            &:hover{
                background-color: var(--secondary);
            
            }
            img{
                width: 220px;
                height: 220px;
                object-fit:cover;
                border-radius: 1em;
                align-self: center;
            }
        }
        @media screen and (max-width:700px) {
            a.button{
                padding:.5rem .7rem;

                img{
                    width: 120px;
                    height: 120px;
                }
            }
        }
        
        p.quote{
            background-color: #000000;
            color: #999999;
            padding:1rem;
            border-radius: 8px;
            width: 80%;
            font-size: 1rem;
            align-self: center;
            margin:1rem 0;
            border: 2px dotted var(--primary);
            &.highlights::before{
                content:"⚡"
            }
            &.important::before{
                content:"⭐"
            }
        }

        article.formula{
            display: flex;
            font-family: monospace;
            flex-direction: row;
            justify-content: center;
            align-items: center;
            gap:1rem;
            color:#ffffff;
            font-style: italic;
            margin: 2rem;
            
            span{
                font-size: .8rem;
                color:orange;

            }
        }
        table{
            border: 1px dotted var(--primary);
            border-radius: 8px;
            padding:1rem 1.5rem;
            font-family:'Lucida Sans', 'Lucida Sans Regular', 'Lucida Grande', 'Lucida Sans Unicode', Geneva, Verdana, sans-serif;
            font-size: .95rem;
            margin:2rem 0;
            background-color: #000000;
            border-spacing: 10px;
            
            thead{
                color:var(--primary);
                font-size:1rem;
            }
            
            td:nth-child(2){
                color:var(--accent);
            }
            td:nth-child(3){
                color:#999999;
                font-size:.8rem;
            }
            
            a{
                text-decoration: none;
                background-color: var(--primary);
                color:white;
                padding:4px 8px;
                border-radius: 4px;
                font-size:.9rem;

             &:hover{
                background-color: var(--secondary);
                color:var(--primary)
             }   
            }
        }
        @media screen and (max-width:700px) {
            table{
                font-size: .8rem;
                margin:1rem 0;
                padding:.32rem;
                td.shrink{
                    display:none;
                }
                a{
                    font-size: .8rem;
                    span{
                        display:none;
                    }
                }
                a::before{
                    content: 'ir';
                }
                
            }
        }


        section.podium{
            display:flex;
            flex-direction: row;
            justify-content: center;
            align-content: flex-start;
            gap:10px;
            flex:1;
            flex-wrap: wrap;
            font-size: .9rem;
            box-sizing: border-box;
            >div{
                background-color: #000000;
                padding:8px 8px;
                border-radius: 8px;
                border:3px solid var(--primary);
                max-width: 190px;
                min-height: 210px;
            }

            h4{
                color:var(--secondary);
                font-size:1.1rem;
                margin-top: 1rem;
            }
            p{
                text-align: justify;

                width: 180px;
            }
        }
        @media screen and (max-width:700px) {
            section.podium{
            
                align-items: center;
                gap:10px;
                p{
                    
                }
            }
        }
    
    }

</style>